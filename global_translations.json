  "ui_text_66": {
    "ES": ">Crea, edita y elimina usuarios de tu sistema.<",
    "PT_BR": ">Cria, edita e elimina usuários do seu sistema.<"
  },
  "ui_text_67": {
    "ES": ">Configura tus ajustes y tu zona horaria.<",
    "PT_BR": ">Configure seus ajustes e seu fuso horário.<"
  },
  "ui_text_68": {
    "ES": ">Accede a registros de Integraciones y Cambios de Asignación de Personal.<",
    "PT_BR": ">Acesse registros de integrações e mudanças de atribuição de pessoal.<"
  },
  "ui_text_69": {
    "ES": ">Define y gestiona ciclos anuales de planificación operativa para organizar horarios y recursos.<",
    "PT_BR": ">Defina e gerencie ciclos anuais de planejamento operacional para organizar horários e recursos.<"
  },
  "ui_text_70": {
    "ES": ">Especificar los tipos de día y días festivos que se aplicarán en tu producto.<",
    "PT_BR": ">Especificar os tipos de dia e dias festivos que serão aplicados em seu produto.<"
  },
  "ui_text_71": {
    "ES": ">Definición de contadores.<",
    "PT_BR": ">Definição de contadores.<"
  },
  "ui_text_72": {
    "ES": ">Accede a información detallada y organiza eficientemente tus unidades dentro del sistema.<",
    "PT_BR": ">Acesse informações detalhadas e organize eficientemente suas unidades dentro do sistema.<"
  },
  "ui_text_73": {
    "ES": ">Crear y gestionar todos los grupos de trabajo existentes. Consulta información detallada y organiza tus grupos dentro del sistema.<",
    "PT_BR": ">Crie e gerencie todos os grupos de trabalho existentes. Consulte informações detalhadas e organize seus grupos no sistema.<"
  },
  "ui_text_74": {
    "ES": ">Crea, edita y elimina conductores de tu sistema.<",
    "PT_BR": ">Crie, edite e elimine motoristas do seu sistema.<"
  },
  "ui_text_75": {
    "ES": ">Añade, edita y activa/desactiva tipos de ausencia.<",
    "PT_BR": ">Adicione, edite e ative/desative tipos de ausência.<"
  },
  "ui_text_76": {
    "ES": ">Crea y gestiona las Reglas de tu empresa.<",
    "PT_BR": ">Crie e gerencie as Regras da sua empresa.<"
  },
  "ui_text_77": {
    "ES": ">Establece diferentes configuraciones para las publicaciones de soluciones.<",
    "PT_BR": ">Estabeleça diferentes configurações para as publicações de soluções.<"
  },
  "ui_text_78": {
    "ES": ">Configuración de las equivalencias de tareas y conductores entre GB.Ops y GoalDriver.<",
    "PT_BR": ">Configuração das equivalências de tarefas e motoristas entre o GB.Ops e o GoalDriver.<"
  },
  "ui_text_79": {
    "ES": ">Administra las características e información de tu Drivers Mobile App.<",
    "PT_BR": ">Gerencie as características e informações do seu Drivers Mobile App.<"
  },
  "ui_text_80": {
    "ES": ">Gestionar la lista de tareas de conducción y no conducción y crear propiedades.<",
    "PT_BR": ">Gerenciar a lista de tarefas de condução e não condução e criar propriedades.<"
  },
  "ui_text_81": {
    "ES": ">Crea, consulta y edita los tipos de turno de tu empresa.<",
    "PT_BR": ">Crie, consulte e edite os tipos de turno da sua empresa.<"
  },
  "ui_text_82": {
    "ES": ">Crea y gestiona las Reglas de Turnos de tu empresa.<",
    "PT_BR": ">Crie e gerencie as Regras de Turnos da sua empresa.<"
  },
  "ui_text_83": {
    "ES": ">Define patrones de turno que cumplen normativa, aseguran descanso y eficiencia operativa.<",
    "PT_BR": ">Defina padrões de turno que cumpram a normativa, garantam o descanso e a eficiência operacional.<"
  },
  "ui_text_84": {
    "ES": ">Registra y gestiona información detallada sobre la operación realizada por los conductores.<",
    "PT_BR": ">Registre e gerencie informações detalhadas sobre a operação realizada pelos motoristas.<"
  },
  "ui_text_85": {
    "ES": ">Crea y edita los tipos de vehículos para tu organización.<",
    "PT_BR": ">Crie e edite os tipos de veículos da sua organização.<"
  },
  "ui_text_86": {
    "ES": ">Añade y actualiza tus modelos de vehículos.<",
    "PT_BR": ">Adicione e atualize seus modelos de veículos.<"
  },
  "ui_text_87": {
    "ES": ">Gestiona tu flota.<",
    "PT_BR": ">Gerencie sua frota.<"
  },
  "ui_text_88": {
    "ES": ">Gestiona los tipos de indisponibilidad de vehículos para tu organización<",
    "PT_BR": ">Gerencie os tipos de indisponibilidade de veículos da sua organização.<"
  },
  "ui_text_89": {
    "ES": ">Configure las reglas de tipo de vehículo de su empresa.<",
    "PT_BR": ">Configure as regras de tipo de veículo da sua empresa.<"
  },
  "ui_text_90": {
    "ES": ">Define y gestiona Modelos de Reglas para soluciones tanto lógicas como nombradas de Larga Distancia.<",
    "PT_BR": ">Defina e gerencie Modelos de Regras para soluções lógicas e nominais de Longa Distância.<"
  },
  "ui_text_91": {
    "ES": ">Consulta y edita los tipos de cargadores eléctricos disponibles en tu organización.<",
    "PT_BR": ">Consulte e edite os tipos de carregadores elétricos disponíveis na sua organização.<"
  },
